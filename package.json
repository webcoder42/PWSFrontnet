{
  "name": "mypsw-merged-workspace",
  "private": true,
  "workspaces": [
    "admin",
    "client",
    "PWS"
  ],
  "scripts": {
    "dev": "npm --prefix PWS run dev",
    "dev:server": "npm --prefix ..\\server start",
    "dev:all": "concurrently \"npm --prefix ..\\server start\" \"npm --prefix PWS run dev\"",
    "build": "npm --prefix PWS run build",
    "preview": "npm --prefix PWS run preview",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@tanstack/query-sync-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2"
  }
}
